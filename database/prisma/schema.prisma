generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/.prisma/client"
}

generator databaseClient {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// User roles for role-based access control
enum Role {
  ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
}

/// System users - Admin, Sales Manager, Sales Executive
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES_EXECUTIVE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads         Lead[]
  followUps     FollowUp[]
  assignedTasks Task[]     @relation("AssignedTasks")
  createdTasks  Task[]     @relation("CreatedTasks")

  @@map("users")
}

/// Status of a lead in the sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

/// Potential customer/lead
model Lead {
  id               String     @id @default(uuid())
  fullName         String     @map("full_name")
  company          String?
  phone            String?
  email            String?
  source           String?
  status           LeadStatus @default(NEW)
  assignedTo       String?    @map("assigned_to")
  address          String?
  notes            String?

  /// Conversion tracking
  isConverted      Boolean    @default(false) @map("is_converted")
  convertedAt      DateTime?  @map("converted_at")
  conversionReason String?    @map("conversion_reason")

  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  assignee         User?      @relation(fields: [assignedTo], references: [id])
  customer         Customer?
  followUps        FollowUp[]
  tasks            Task[]

  @@map("leads")
}

/// Converted lead customer record — created only via lead conversion
model Customer {
  id            String   @id @default(uuid())
  leadId        String   @unique @map("lead_id")
  company       String?
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  address       String?
  industry      String?
  notes         String?

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lead          Lead     @relation(fields: [leadId], references: [id])
  tasks         Task[]

  @@map("customers")
}

/// Priority of a follow-up
enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Type of follow-up interaction
enum FollowUpType {
  PHONE_CALL
  WHATSAPP
  EMAIL
  MEETING
  SITE_VISIT
  DEMO
  OTHER
}

/// Status of the follow-up
enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
  CANCELLED
}

/// Follow-up interaction with a lead
model FollowUp {
  id               String           @id @default(uuid())
  leadId           String           @map("lead_id")
  followUpDate     DateTime         @map("follow_up_date") // Date part
  followUpTime     String?          @map("follow_up_time") // Time part (HH:mm)
  reminderTime     String?          @map("reminder_time")  // Reminder time
  type             FollowUpType     @default(PHONE_CALL)
  status           FollowUpStatus   @default(PENDING)
  priority         FollowUpPriority @default(MEDIUM)
  notes            String?
  outcomeNotes     String?          @map("outcome_notes")
  nextFollowUpDate DateTime?        @map("next_follow_up_date")
  
  createdBy        String           @map("created_by")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  lead             Lead             @relation(fields: [leadId], references: [id])
  creator          User             @relation(fields: [createdBy], references: [id])

  @@map("follow_ups")
}

/// Priority level of a task
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Lifecycle status of a task
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Internal work item assigned to a team member, optionally linked to a Lead or Customer
model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  assignedUserId String       @map("assigned_user_id")
  leadId         String?      @map("lead_id")
  customerId     String?      @map("customer_id")
  createdBy      String       @map("created_by")
  dueDate        DateTime     @map("due_date")
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(PENDING)
  remarks        String?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  assignedUser   User         @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  creator        User         @relation("CreatedTasks", fields: [createdBy], references: [id])
  lead           Lead?        @relation(fields: [leadId], references: [id])
  customer       Customer?    @relation(fields: [customerId], references: [id])

  @@map("tasks")
}
