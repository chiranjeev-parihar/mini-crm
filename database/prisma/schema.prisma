generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/.prisma/client"
}

generator databaseClient {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// User roles for role-based access control
enum Role {
  ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
}

/// System users - Admin, Sales Manager, Sales Executive
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES_EXECUTIVE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads     Lead[]

  @@map("users")
}

/// Status of a lead in the sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

/// Potential customer/lead
model Lead {
  id               String     @id @default(uuid())
  fullName         String     @map("full_name")
  company          String?
  phone            String?
  email            String?
  source           String?
  status           LeadStatus @default(NEW)
  assignedTo       String?    @map("assigned_to")
  address          String?
  notes            String?

  /// Conversion tracking
  isConverted      Boolean    @default(false) @map("is_converted")
  convertedAt      DateTime?  @map("converted_at")
  conversionReason String?    @map("conversion_reason")

  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  assignee         User?      @relation(fields: [assignedTo], references: [id])
  customer         Customer?

  @@map("leads")
}

/// Converted lead customer record — created only via lead conversion
model Customer {
  id            String   @id @default(uuid())
  leadId        String   @unique @map("lead_id")
  company       String?
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  address       String?
  industry      String?
  notes         String?

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lead          Lead     @relation(fields: [leadId], references: [id])

  @@map("customers")
}
